# d:\Program_project\RAG_MCP_project_ForAlg\.env

PDF_FILE_PATH="./Introduction_to_algorithms-3rd Edition.pdf"
VECTOR_DB_PATH="./chroma_db"
EMBEDDING_MODEL='BAAI/bge-m3'
COLLECTION_NAME="my_pdf_collection"
RETRIEVAL_SERVER_URL=""
GOOGLE_API_KEY_LLM= # 請替換成您安全的 API 金鑰
LLM_MODEL_NAME="gemini-1.5-flash-latest"
EMBEDDING_DEVICE="cuda" # 強制使用 CUDA GPU，如果不可用，SentenceTransformer 通常會報錯或回退到 CPU
PARENT_CHUNKS_FILE_PATH="./parent_chunks_store.json" # 父區塊儲存路徑
USE_HYDE_QUERY_EXPANSION=true # 增強查詢處理和理解： 查詢重寫與擴展： 處理模糊查詢，轉換為更精確的形式（如 MaFeRw, HyDE）。
PERFORM_QUERY_DECOMPOSITION=true # 查詢分解： 將複雜問題分解為更簡單的子問題。

# CROSS_ENCODER_MODEL_NAME="cross-encoder/ms-marco-MiniLM-L-6-v2"
